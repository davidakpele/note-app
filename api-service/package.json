{
  "name": "api-service",
  "version": "1.0.0",
  "description": "Notes REST API — Controller / Service / Repository architecture",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:migrate": "node src/db/migrate.js && node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/db/migrate.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand --forceExit",
    "test:integration": "jest tests/integration --runInBand --forceExit"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.0",
    "express": "^5.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.1.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "jest": "^30.1.3",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  }
}
